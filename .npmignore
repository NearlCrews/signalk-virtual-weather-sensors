# Source files (only ship dist/)
src/
*.ts
!*.d.ts
tsconfig.json
vitest.config.ts

# Tests
**/__tests__/
**/*.test.ts
**/*.spec.ts
coverage/
.vitest/

# Development configuration
.github/
.husky/
.claude/
.vscode/
.idea/
esbuild.config.js
biome.json
.node-version

# Documentation (only ship README, LICENSE, CHANGELOG)
DEVELOPMENT.md
CONTRIBUTING.md
TODO.md
RELEASE.md
CLAUDE.md
CODE_OF_CONDUCT.md
SECURITY.md

# Git
.git/
.gitignore

# Build artifacts not needed
*.tsbuildinfo
.eslintcache

# OS files
.DS_Store
Thumbs.db

# Logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Temp files
*.swp
*.swo
*~
tmp/
temp/

# Package managers
yarn.lock
pnpm-lock.yaml
.pnpm-debug.log

# Environment files
.env
.env.test
.env.local
.env.production
