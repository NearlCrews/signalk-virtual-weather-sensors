{
  "name": "signalk-virtual-weather-sensors",
  "version": "1.4.4",
  "description": "Signal K plugin that provides comprehensive weather data from AccuWeather API with calculated wind values and NMEA2000-compatible environmental measurements",
  "keywords": [
    "signalk-node-server-plugin",
    "signalk-category-weather",
    "signalk-category-nmea-2000",
    "nmea2000",
    "weather",
    "accuweather",
    "typescript",
    "marine",
    "sailing",
    "boat",
    "navigation",
    "sensor",
    "weather-station",
    "wind-calculator",
    "apparent-wind",
    "true-wind",
    "maritime",
    "iot"
  ],
  "signalk-plugin-enabled-by-default": false,
  "signalk": {
    "displayName": "Virtual Weather Sensors",
    "appIcon": "./assets/icons/icon-192.png"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "sideEffects": false,
  "files": [
    "dist/",
    "assets/icons/",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "author": "Nearl Crews",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/NearlCrews/signalk-virtual-weather-sensors.git"
  },
  "bugs": {
    "url": "https://github.com/NearlCrews/signalk-virtual-weather-sensors/issues"
  },
  "homepage": "https://github.com/NearlCrews/signalk-virtual-weather-sensors#readme",
  "engines": {
    "node": ">=20.18"
  },
  "type": "module",
  "peerDependencies": {
    "@signalk/server-api": ">=2.24.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@signalk/server-api": "^2.24.0",
    "@signalk/signalk-schema": "^1.8.2",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@types/node": "^25.6.2",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.17",
    "ajv": "^8.20.0",
    "ajv-draft-04": "^1.0.0",
    "ajv-formats": "^3.0.1",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.0.17"
  },
  "scripts": {
    "build": "npm run clean && npm run build:types && npm run build:bundle",
    "build:types": "tsc --noEmit false --declaration --emitDeclarationOnly --outDir dist",
    "build:bundle": "node esbuild.config.js",
    "dev": "tsx watch src/index.ts",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:run": "vitest run",
    "mutation-test": "stryker run",
    "type-check": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "rm -rf dist/",
    "validate": "npm run type-check && npm run lint && npm run test:run",
    "security-audit": "npm audit --audit-level=moderate",
    "prepack": "npm run build",
    "prepublishOnly": "npm run validate && npm run build",
    "prepare": "husky || true",
    "create-release": "gh release create v$npm_package_version --generate-notes",
    "release": "git rev-parse \"v$npm_package_version\" >/dev/null 2>&1 && { echo \"tag v$npm_package_version already exists\"; exit 1; } ; git tag v$npm_package_version && git push --tags && git push && npm run create-release"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "biome check --write",
      "biome format --write"
    ],
    "*.{json,md}": [
      "biome format --write"
    ]
  }
}
